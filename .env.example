# Supabase — create a project at https://supabase.com/dashboard, then copy values from
# Project Settings → API. Apply supabase/migrations/0001_init.sql via the SQL editor or CLI.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis — create at https://console.upstash.com/redis (REST API)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron auth — generate with: openssl rand -hex 32
CRON_SECRET=

# Bayse — request access at https://docs.bayse.markets (HMAC-SHA256 auth)
# Adapter at lib/ingest/bayse.ts is wired but no-ops without these.
BAYSE_API_KEY=
BAYSE_API_SECRET=

# Detection threshold — markets below this liquidity (USD) are filtered out
MIN_LIQUIDITY=5000
